{
    "family": "feeder-task",
    "containerDefinitions": [
        {
            "name": "app",
            "image": "353925322579.dkr.ecr.ap-southeast-2.amazonaws.com/feeder-app:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/feeder-task",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "networkMode": "awsvpc",
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::353925322579:role/LabRole",
    "taskRoleArn": "arn:aws:iam::353925322579:role/LabRole"
}